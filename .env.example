# =============================================================================
# template-mcp — ENV-Vars
# Kopiere diese Datei nach `.env` und fuelle die Secrets ein.
# =============================================================================

# ---------- Server -----------------------------------------------------------
MCP_SERVER_NAME=template-mcp
HOST=0.0.0.0
PORT=5002
LOG_LEVEL=INFO

# Origin-Whitelist (DNS-Rebinding-Schutz). Komma-Liste, leer = aus.
# Beispiel: https://claude.ai,https://chat.openai.com
MCP_ALLOWED_ORIGINS=

# Rate-Limit pro Client-IP pro Minute (0 = aus)
MCP_RATE_LIMIT_PER_MIN=60

# ---------- Storage ----------------------------------------------------------
# Container-Pfad fuer Daten — host-mount via volume
DATA_PATH=/data

# ---------- Audit + Snapshots ------------------------------------------------
MCP_AUDIT_LOG=/var/log/mcp/audit.log
MCP_SNAPSHOT_DIR=/snapshots
MCP_SNAPSHOT_ENABLED=1

# ---------- Auth: Bearer-Token (statisch) -----------------------------------
# Fuer Bot/CLI/Scripts. Mind. 32 Zeichen, am besten 64. Generieren via:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
MCP_TOKEN=

# ---------- Auth: OAuth 2.1 (fuer claude.ai, ChatGPT, Cursor, etc.) ---------
# Single-User Setup. Wenn alle drei Werte gesetzt sind, ist OAuth aktiv.

# Email als Login-Identifier
OAUTH_USER_EMAIL=

# bcrypt-Hash des Passworts. Generieren via:
#   python scripts/set_oauth_password.py
# Achtung: docker-compose env_file interpretiert `$` als Variable. Doppeln:
#   sed -i '/^OAUTH_PASSWORD_HASH=/ s|\$\+|$$|g' .env
OAUTH_PASSWORD_HASH=

# JWT-Signing-Secret (HS256). Mind. 32 Zeichen. Generieren via:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
OAUTH_JWT_SECRET=

# Pfad fuer SQLite-DB mit Clients + Refresh-Tokens
OAUTH_DB_PATH=/var/lib/mcp-oauth/oauth.db

# Issuer + Resource — muessen mit deiner Public-URL uebereinstimmen
OAUTH_ISSUER=https://mcp.example.com
OAUTH_RESOURCE=https://mcp.example.com/mcp/

# Token-Lifetimes in Sekunden (defaults: 15 Min Access, 3 Tage Refresh)
OAUTH_ACCESS_TTL=900
OAUTH_REFRESH_TTL=259200
